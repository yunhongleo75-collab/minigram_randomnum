<view class="container">
  <!-- Custom Centered Navigation Bar -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="nav-title">随机数水晶球</view>
  </view>

  <!-- Header / Title -->
  <view class="header">
    <text class="title">水晶球之旅</text>
  </view>

  <!-- Crystal Ball Section -->
  <view class="crystal-ball-container">
    <view class="crystal-ball {{isRotating ? 'rotating' : ''}}">
      <view class="reflection-top"></view>
      <view class="content-wrapper">
        <block wx:if="{{results.length > 0 && !isRotating}}">
          <view class="result-list">
            <view wx:for="{{results}}" wx:key="index" class="result-item show {{results.length === 2 ? 'medium' : (results.length === 3 ? 'small' : '')}}">
              {{item}}
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="stars-container {{isRotating ? 'rotating-stars' : ''}}">
            <text wx:if="{{isRotating}}" class="rotating-placeholder">???</text>
            <block wx:else>
              <view class="star star-1"></view>
              <view class="star star-2"></view>
              <view class="star star-3"></view>
              <view class="star star-4"></view>
              <view class="star star-5"></view>
            </block>
          </view>
        </block>
      </view>
      <view class="reflection-bottom"></view>
    </view>
    <view class="crystal-base"></view>
  </view>


  <!-- Settings and Controls -->
  <view class="controls-panel">
    <view class="settings-group">
      <view class="setting-item">
        <text class="label">最小值</text>
        <input class="input" type="number" value="{{min}}" bindinput="onMinInput" />
      </view>
      <view class="setting-item">
        <text class="label">最大值</text>
        <input class="input" type="number" value="{{max}}" bindinput="onMaxInput" />
      </view>
      <view class="setting-item">
        <text class="label">个数</text>
        <input class="input" type="number" value="{{count}}" bindinput="onCountInput" />
      </view>
    </view>
    
    <view class="btn-group">
      <button class="btn reset-btn {{isRotating ? 'disabled' : ''}}" bindtap="resetResults" disabled="{{isRotating}}">重置</button>
      <button class="btn generate-btn {{isRotating ? 'disabled' : ''}}" bindtap="generateNumbers" disabled="{{isRotating}}">
        {{isRotating ? '正在生成...' : '生成'}}
      </button>
    </view>
  </view>

  <!-- Result Scroll Modal -->
  <view class="scroll-overlay {{showScroll ? 'active' : ''}}" bindtap="closeScroll">
    <view class="scroll-container {{showScroll ? 'slide-up' : ''}}" catchtap="true">
      <view class="scroll-header">
        <view class="scroll-spindle left"></view>
        <view class="scroll-paper">生成结果</view>
        <view class="scroll-spindle right"></view>
      </view>
      <scroll-view scroll-y class="scroll-body">
        <view class="scroll-result-list">
          <view wx:for="{{results}}" wx:key="index" class="scroll-result-item">
            <text class="result-index">{{index + 1}}</text>
            <text class="result-value">{{item}}</text>
          </view>
        </view>
        <view class="scroll-footer">
          <button class="close-btn" bindtap="closeScroll">返回</button>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
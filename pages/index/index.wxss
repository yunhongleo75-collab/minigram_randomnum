.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx 40rpx;
  background: radial-gradient(circle at center, #ffffff 0%, #f0f2f5 100%);
  min-height: 100vh;
}

/* Custom Centered Nav Bar */
.nav-bar {
  width: 100%;
  position: fixed;
  top: 0;
  left: 0;
  display: flex;
  justify-content: center; /* Center horizontally */
  align-items: center;
  background: #ffffff;
  z-index: 1000;
  box-sizing: border-box;
}

.nav-title {
  font-size: 44rpx; /* Increased as requested */
  font-weight: 600;
  color: #333;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  margin-top: 180rpx; /* Push content down below fixed nav bar */
}

.title {
  font-size: 60rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
  -webkit-background-clip: text;
  color: transparent;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  letter-spacing: 4rpx;
  margin-top: 10rpx;
}

/* Crystal Ball Styling */
.crystal-ball-container {
  position: relative;
  width: 450rpx;
  height: 450rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 80rpx;
}

.crystal-ball {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(30, 136, 229, 0.4) 0%, rgba(13, 71, 161, 0.2) 50%, rgba(255, 255, 255, 0.1) 100%);
  box-shadow: 
    0 20rpx 60rpx rgba(13, 71, 161, 0.2),
    inset 0 0 80rpx rgba(255, 255, 255, 0.5);
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  backdrop-filter: blur(14px);
  border: 4rpx solid rgba(13, 71, 161, 0.3);
  transition: all 0.5s ease-out;
  z-index: 2;
}

.crystal-ball.rotating {
  animation: rotateBall 2s linear infinite;
  box-shadow: 
    0 40rpx 100rpx rgba(13, 71, 161, 0.4),
    inset 0 0 120rpx rgba(255, 255, 255, 0.6);
}

.reflection-top {
  position: absolute;
  top: 15%;
  left: 20%;
  width: 100rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  transform: rotate(-30deg);
  filter: blur(5px);
}

.reflection-bottom {
  position: absolute;
  bottom: 10%;
  right: 15%;
  width: 150rpx;
  height: 30rpx;
  background: rgba(161, 196, 253, 0.15);
  border-radius: 50%;
  filter: blur(8px);
}

.crystal-base {
  position: absolute;
  bottom: -20rpx;
  width: 280rpx;
  height: 60rpx;
  background: linear-gradient(to bottom, #333 0%, #111 100%);
  border-radius: 50% / 20rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.5);
  z-index: 1;
}


.content-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  width: 100%;
  height: 100%;
}

.placeholder {
  font-size: 100rpx;
  transition: all 0.3s;
}

.placeholder.pulse {
  animation: pulse 1s infinite alternate;
}

.result-list {
  display: flex;
  flex-direction: column; /* Stack vertically for 1-2 results */
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  max-width: 90%;
}

.result-item {
  font-size: 130rpx;
  font-weight: bold;
  color: #1e88e5;
  text-shadow: 0 4rpx 25rpx rgba(30, 136, 229, 0.5);
}

.result-item.medium {
  font-size: 100rpx;
  text-shadow: 0 4rpx 20rpx rgba(30, 136, 229, 0.45);
}

.result-item.small {
  font-size: 80rpx;
  text-shadow: 0 2rpx 15rpx rgba(30, 136, 229, 0.4);
}

.result-item.show {
  animation: bounceIn 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

/* Controls Panel Styling */
.controls-panel {
  width: 90%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  border-radius: 40rpx;
  padding: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 1);
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.05);
}

.settings-group {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.setting-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 10rpx;
}

.label {
  font-size: 40rpx;
  color: #1a237e;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.input {
  width: 120rpx;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 20rpx;
  text-align: center;
  font-size: 40rpx;
  color: #333;
  border: 1px solid rgba(0, 0, 0, 0.05);
}

.btn-group {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
}

.btn {
  flex: 1;
  height: 100rpx;
  padding: 0;
  margin: 0;
  border-radius: 50rpx;
  font-size: 38rpx;
  font-weight: bold;
  transition: all 0.3s;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
}

.reset-btn {
  background: #ffffff;
  color: #1e3c72;
  border: 4rpx solid #1e3c72;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.generate-btn {
  background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
  color: white;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(30, 136, 229, 0.4);
}

.btn.disabled {
  opacity: 0.6;
  background: #f0f0f0;
  color: #999;
  border-color: #ddd;
  box-shadow: none;
}

.generate-btn.disabled {
  background: #444;
  color: #888;
}

/* Result Scroll Modal */
.scroll-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8px);
  z-index: 2000;
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.scroll-overlay.active {
  opacity: 1;
  visibility: visible;
}

.scroll-container {
  position: relative;
  width: 85%;
  max-height: 80vh; /* Increased to allow more room */
  background: #fdfaf2;
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 40rpx 100rpx rgba(0, 0, 0, 0.3);
  transform: translateY(100rpx) scale(0.9);
  transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.scroll-container.slide-up {
  transform: translateY(0) scale(1);
}

.scroll-header {
  height: 120rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  background: linear-gradient(to bottom, #1a237e 0%, #283593 100%);
  border-radius: 40rpx 40rpx 0 0;
  color: white;
  font-size: 36rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.scroll-spindle {
  position: absolute;
  top: 50%;
  width: 40rpx;
  height: 140rpx;
  background: linear-gradient(to right, #444 0%, #222 100%);
  border-radius: 10rpx;
  transform: translateY(-50%);
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.5);
}

.scroll-spindle.left { left: -20rpx; }
.scroll-spindle.right { right: -20rpx; }

.scroll-body {
  height: 600rpx; /* Set an explicit height for the scroll-view to function correctly */
  max-height: 65vh; 
  padding: 40rpx;
  box-sizing: border-box;
}

.scroll-result-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.scroll-result-item {
  display: flex;
  align-items: center;
  background: white;
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  border: 1px solid rgba(26, 35, 126, 0.1);
}

.result-index {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
  font-family: serif;
}

.result-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a237e;
}

.scroll-footer {
  padding: 30rpx 40rpx 40rpx;
  display: flex;
  justify-content: center;
}

.close-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(26, 35, 126, 0.1);
  color: #1a237e;
  border: 4rpx solid #1a237e;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* Animations rewrite */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes rotateBall {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes pulse {
  from { opacity: 0.4; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1.1); }
}

@keyframes bounceIn {
  from { opacity: 0; transform: scale(0.3); }
  50% { opacity: 1; transform: scale(1.1); }
  70% { transform: scale(0.9); }
  to { transform: scale(1); }
}

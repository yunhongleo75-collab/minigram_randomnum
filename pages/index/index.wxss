.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: radial-gradient(circle at center, #ffffff 0%, #f0f2f5 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  -webkit-background-clip: text;
  color: transparent;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
  letter-spacing: 4rpx;
  margin-top: 10rpx;
}

/* Crystal Ball Styling */
.crystal-ball-container {
  position: relative;
  width: 450rpx;
  height: 450rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 80rpx;
}

.crystal-ball {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(168, 85, 247, 0.4) 0%, rgba(123, 47, 247, 0.2) 50%, rgba(255, 255, 255, 0.1) 100%);
  box-shadow: 
    0 20rpx 60rpx rgba(123, 47, 247, 0.2),
    inset 0 0 80rpx rgba(255, 255, 255, 0.5);
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  backdrop-filter: blur(12px);
  border: 4rpx solid rgba(123, 47, 247, 0.3);
  transition: all 0.5s ease-out;
  z-index: 2;
}

.crystal-ball.rotating {
  animation: rotateBall 2s linear infinite;
  box-shadow: 
    0 40rpx 100rpx rgba(123, 47, 247, 0.4),
    inset 0 0 120rpx rgba(255, 255, 255, 0.6);
}

.reflection-top {
  position: absolute;
  top: 15%;
  left: 20%;
  width: 100rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  transform: rotate(-30deg);
  filter: blur(5px);
}

.reflection-bottom {
  position: absolute;
  bottom: 10%;
  right: 15%;
  width: 150rpx;
  height: 30rpx;
  background: rgba(161, 196, 253, 0.15);
  border-radius: 50%;
  filter: blur(8px);
}

.crystal-base {
  position: absolute;
  bottom: -20rpx;
  width: 280rpx;
  height: 60rpx;
  background: linear-gradient(to bottom, #333 0%, #111 100%);
  border-radius: 50% / 20rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.5);
  z-index: 1;
}

.content-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  width: 100%;
  height: 100%;
}

.placeholder {
  font-size: 100rpx;
  transition: all 0.3s;
}

.placeholder.pulse {
  animation: pulse 1s infinite alternate;
}

.result-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx;
}

.result-item {
  font-size: 80rpx;
  font-weight: bold;
  color: #7b2ff7;
  text-shadow: 0 4rpx 15rpx rgba(123, 47, 247, 0.3);
}

.result-item.show {
  animation: bounceIn 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

/* Controls Panel Styling */
.controls-panel {
  width: 90%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20px);
  border-radius: 40rpx;
  padding: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 1);
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.05);
}

.settings-group {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.setting-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0 10rpx;
}

.label {
  font-size: 36rpx;
  color: #764ba2;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.input {
  width: 100rpx;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 20rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  border: 1px solid rgba(0, 0, 0, 0.05);
}

.generate-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(118, 75, 162, 0.4);
  transition: all 0.3s;
}

.generate-btn.disabled {
  opacity: 0.6;
  background: #444;
  box-shadow: none;
}

/* Animations */
@keyframes rotateBall {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes pulse {
  from { opacity: 0.4; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1.1); }
}

@keyframes bounceIn {
  from { opacity: 0; transform: scale(0.3); }
  50% { opacity: 1; transform: scale(1.1); }
  70% { transform: scale(0.9); }
  to { transform: scale(1); }
}
